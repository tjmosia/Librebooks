{
  "version": "3.0",
  "defaultProvider": "jsdelivr",
  "libraries": [
    {
      "library": "jquery@4.0.0",
      "destination": "wwwroot/libs/jquery/"
    },
    {
      "provider": "cdnjs",
      "library": "animate.css@4.1.1",
      "destination": "wwwroot/libs/animate.css/"
    },
    {
      "provider": "cdnjs",
      "library": "tailwindcss-browser@4.1.13",
      "destination": "wwwroot/assets/libs/tailwindcss-browser/"
    },
    {
      "provider": "cdnjs",
      "library": "jquery-validation-unobtrusive@4.0.0",
      "destination": "wwwroot/assets/libs/jquery-validation-unobtrusive/"
    },
    {
      "library": "jquery-validation@1.22.1",
      "destination": "wwwroot/assets/libs/jquery-validation/"
    }
  ]
}