@page "/auth"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@inject UserManagerExtension UserManager
@inject NavigationManager NavigationManager
<PageTitle>Sign In or Sign Up</PageTitle>
<EditForm OnValidSubmit=@OnSubmitHandler Model=@Input FormName="EmailForm">
	<DataAnnotationsValidator />
	<div>
		<label for="id_email">Email Address</label>
		<div>
			<InputText @bind-Value="Input!.Email" id="id_email" />
		</div>
		<ValidationMessage For="@(() => Input!.Email)" />
	</div>
	<div>
		<button type="submit">
			<span>Continue</span>
		</button>
	</div>
</EditForm>

@code {
	[SupplyParameterFromQuery]
	public string? ReturnUrl { get; set; }

	public Dictionary<string, string>? Errors { get; set; }

	[CascadingParameter]
	public AuthLayout? AuthLayout { get; set; }

	[SupplyParameterFromForm]
	public Model? Input { get; set; }

	public async Task OnSubmitHandler()
	{
		var user = await UserManager.FindByEmailAsync(Input!.Email!);
		if(user != null)
		{
			NavigationManager.NavigateTo($"/auth/signin?returnUrl={ReturnUrl}");
		}
		else
		{
			NavigationManager.NavigateTo($"/auth/signin?email={Input.Email}&returnUrl={ReturnUrl}", forceLoad: true);
		}

	}

	protected override void OnInitialized()
	{
		AuthLayout?.SetFormTitle("Sign In or Sign Up");
		Input = Input ?? new();
		Errors = Errors ?? new();
		base.OnInitialized();
	}

	public class Model
	{
		[Required(ErrorMessage = "Email is required.")]
		public string? Email { get; set; }

		[Required(ErrorMessage = "Password is required.")]
		public string? Password { get; set; }
	}
}
